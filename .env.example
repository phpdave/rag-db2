# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional overrides ────────────────────────────────────────────────────────

# URL of the PDF to ingest at startup (or POST to /ingest/url later)
PDF_URL=https://www.ibm.com/docs/es/ssw_ibm_i_75/pdf/rbafzpdf.pdf

# Hugging Face model for embeddings.
# BAAI/bge-large-en-v1.5 (1024-dim) is a great balance of quality and speed.
# Lighter alternative: BAAI/bge-base-en-v1.5 (768-dim)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# Chunk size in words (~0.75× tokens).  400 words ≈ 530 tokens.
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ── IBM i connection (pub400.com or your own system) ──────────────────────────
IBMI_HOST=pub400.com
IBMI_PORT=446
IBMI_USER=your_pub400_username
IBMI_PASSWORD=your_pub400_password
IBMI_SSL=0
IBMI_DEFAULT_SCHEMA=your_default_library
